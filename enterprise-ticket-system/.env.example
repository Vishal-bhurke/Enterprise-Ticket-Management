# =====================================================================
# ENVIRONMENT VARIABLE TEMPLATE
# Copy this file to .env and fill in your real values.
# .env is gitignored — .env.example is safe to commit.
# =====================================================================

# Supabase project
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here
SUPABASE_SERVICE_KEY=sb_secret_your_service_key_here

# Playwright test configuration
PLAYWRIGHT_BASE_URL=http://localhost:4200
PLAYWRIGHT_SUPABASE_URL=https://your-project.supabase.co
PLAYWRIGHT_ANON_KEY=sb_publishable_your_anon_key_here

# Test user credentials
TEST_SUPER_ADMIN_EMAIL=test_superadmin@playwright.local
TEST_SUPER_ADMIN_PASSWORD=PlaywrightTest123!
TEST_ADMIN_EMAIL=test_admin@playwright.local
TEST_ADMIN_PASSWORD=PlaywrightTest123!
TEST_AGENT_EMAIL=test_agent@playwright.local
TEST_AGENT_PASSWORD=PlaywrightTest123!
TEST_END_USER_EMAIL=test_enduser@playwright.local
TEST_END_USER_PASSWORD=PlaywrightTest123!
